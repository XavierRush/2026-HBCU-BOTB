{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "python",
            "request": "launch",
            "name": "Streamlit Debug Mode",
            "cwd": "${workspaceFolder}",
            "module": "streamlit",
            "args": [
                "run",
                "dashboard/app.py",
                "--server.port",
                "8501"
            ],
            "env": {
                "DEBUG_MODE": "1"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "type": "python",
            "request": "launch",
            "name": "Streamlit Live Claude",
            "cwd": "${workspaceFolder}",
            "module": "streamlit",
            "args": [
                "run",
                "dashboard/app.py",
                "--server.port",
                "8501"
            ],
            "env": {
                "DEBUG_MODE": "0"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
